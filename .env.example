# ============================================
#   Python Teacher Bot — конфигурация
#   Провайдер LLM: NVIDIA NIM
# ============================================

# ── Telegram ─────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROUP_CHAT_ID=455464577784369

# ── Расписание (UTC) ──────────────────────────
POST_TIMES=08:00,19:00
LESSON_DAYS=mon,thu

# ── NVIDIA NIM ────────────────────────────────
# Получить ключ: build.nvidia.com → твой аккаунт → API Keys
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Выбери модель (раскомментируй нужную):
OLLAMA_MODEL=meta/llama-4-maverick-17b-128e-instruct     # рекомендую
# OLLAMA_MODEL=qwen/qwen3-30b-a3b     # Qwen3 30B MoE — быстрее
# OLLAMA_MODEL=qwen/qwen3-32b         # Qwen3 32B — баланс
# OLLAMA_MODEL=meta/llama-4-scout-17b-16e-instruct  # Llama 4 — альтернатива

# Таймауты (внешний API — чуть больше чем для localhost)
OLLAMA_CONNECT_TIMEOUT=10.0
OLLAMA_READ_TIMEOUT=120.0

# Параметры генерации
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_NUM_PREDICT=1024

# Retry (при rate limit 429 бот подождёт и повторит)
LLM_RETRIES=3
LLM_RETRY_DELAY=1.0

# ── Пути ──────────────────────────────────────
MATERIALS_DIR=materials
DATABASE_URL=sqlite+aiosqlite:///data/pyteacher.db

# ── Логика ────────────────────────────────────
DEFAULT_MODE=mixed
MAX_USED_QUESTIONS=60
FRESH_LESSON_HOURS=48
